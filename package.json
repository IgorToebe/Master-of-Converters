{
  "name": "conversor-de-audio",
  "version": "1.0.0",
  "description": "Conversor de áudio com Electron, Vue 3 e Vite",
  "main": "web-server/server.js",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:desktop": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:web": "concurrently -k \"npm:dev:web:server\" \"npm:dev:web:client\"",
    "dev:web:server": "node web-server/server.js",
    "dev:web:client": "vite --host 0.0.0.0 --port 5173 --open",
    "dev:renderer": "vite",
    "dev:renderer:host": "vite --host 0.0.0.0 --port 5173",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:tunnel": "ngrok http 5173",
    "dev:public": "concurrently -k \"npm:dev:renderer:host\" \"npm:dev:tunnel\"",
    "build": "npm run build:renderer && npm run build:electron && electron-builder",
    "build:dist": "npm run build:renderer && npm run build:electron",
    "build:win": "npm run build:dist && electron-builder --win nsis",
    "build:mac": "npm run build:dist && electron-builder --mac dmg zip --universal",
    "build:renderer": "vite build",
    "build:web": "vite build",
    "build:electron": "node scripts/prepare-electron.mjs",
    "start": "npm run start:web",
    "start:desktop": "cross-env NODE_ENV=production electron .",
    "start:web": "cross-env NODE_ENV=production node web-server/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ffmpeg-static": "5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-vue-next": "^1.0.0",
    "multer": "^1.4.5-lts.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "ngrok": "^5.0.0-beta.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.2",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.local.conversordeaudio",
    "productName": "Conversor de Áudio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "extraResources": [
      {
        "from": "build-resources/ffmpeg-bin",
        "to": "ffmpeg-bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "dist-electron/main/main.js"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
